{
    "editor.linkedEditing": true,
    "editor.minimap.enabled": true,
    "editor.foldingStrategy": "indentation",
    "editor.quickSuggestions": {
        "strings": "on"
    },
    "editor.tabSize": 2,
    "editor.codeActionsOnSave": {
        "source.fixAll": "always"
    },
    "editor.copyWithSyntaxHighlighting": false,
    "editor.minimap.autohide": true,
    "explorer.confirmDragAndDrop": false,
    "emmet.syntaxProfiles": {
        "javascript": "jsx"
    },
    "emmet.includeLanguages": {
        "javascript": "html",
        "twig": "html"
    },
    "explorer.confirmDelete": false,
    "liveServer.settings.donotShowInfoMsg": true,
    "security.workspace.trust.untrustedFiles": "open",
    "tailwindCSS.includeLanguages": {
        "plaintext": "html"
    },
    "terminal.integrated.defaultProfile.linux": "zsh",
    "liveServer.settings.fullReload": true,
    "liveServer.settings.ignoreFiles": [
        ".vscode/**",
        "**/*.scss",
        "**/*.sass",
        "**/*.ts",
        "node_modules/**",
        "tailwind.css"
    ],
    "hardhat.telemetry": false,
    "workbench.startupEditor": "none",
    "css.lint.unknownAtRules": "ignore",
    "[prisma]": {
        "editor.formatOnSave": true
    },
    "workbench.iconTheme": "vscode-icons",
    "tabnine.experimentalAutoImports": true,
    "javascript.preferences.quoteStyle": "single",
    "typescript.preferences.quoteStyle": "single",
    "vsicons.dontShowNewVersionMessage": true,
    "ibm-blockchain-platform.v2.fabric.runtime": {
        "1 Org Local Fabric": 8080
    },
    "remote.SSH.remotePlatform": {
        "192.168.0.106": "linux"
    },
    "javascript.preferences.importModuleSpecifierEnding": "index",
    "typescript.preferences.importModuleSpecifierEnding": "index",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    // "[javascript]": {
    //     "editor.defaultFormatter": "esbenp.prettier-vscode"
    // },
    "git.autofetch": true,
    "[solidity]": {},
    "svelte.enable-ts-plugin": true,
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "terminal.integrated.fontFamily": "MesloLGS NF",
    "gopls": {
        "ui.semanticTokens": true
    },
    "diffEditor.ignoreTrimWhitespace": false,
    "cairo1.enableScarb": true,
    "cairo1.enableLanguageServer": true,
    "makefile.configureOnOpen": false,
    "workbench.colorTheme": "Default Dark Modern",
    "[markdown]": {
        "diffEditor.ignoreTrimWhitespace": true
    },
    "git.openRepositoryInParentFolders": "never",
    "cursor.cpp.disabledLanguages": [
        "plaintext"
    ],
    "git.enableSmartCommit": true,
    "githubPullRequests.pullBranch": "never",
    "cursor.cpp.enablePartialAccepts": true,
    "gitlens.rebaseEditor.ordering": "asc",
    "workbench.activityBar.orientation": "vertical",
    
    // Golang
    "go.testTimeout": "40s",
    "go.toolsManagement.autoUpdate": true,

    // linter
    // "go.lintTool": "golangci-lint",
    // "go.lintFlags": [
    //     "--path-mode=abs",
    //     "--allow-parallel-runners",
    //     "--fix"
    //     ],
    // "go.formatTool": "custom",
    // "go.alternateTools": {
    //     "customFormatter": "golangci-lint"
    // },
    // "go.formatFlags": [
    //     "fmt",
    //     "--stdin"
    // ],
    //
    
    "go.editorContextMenuCommands": {
        "toggleTestFile": false,
        "addTags": false,
        "compilerDetails": true,
        "removeTags": false,
        "fillStruct": true,
        "testAtCursor": false,
        "testFile": false,
        "testPackage": false,
        "generateTestForFunction": false,
        "generateTestForFile": false,
        "generateTestForPackage": false,
        "addImport": false,
        "testCoverage": false,
        "playground": false,
        "debugTestAtCursor": false,
        "benchmarkAtCursor": false,
    },
    "githubPullRequests.fileListLayout": "tree",
    "gitlens.ai.model": "gitkraken",
    "gitlens.ai.gitkraken.model": "gemini:gemini-2.0-flash",
    "editor.largeFileOptimizations": false,
    "gitlens.views.scm.grouped.views": {
        "commits": true,
        "branches": true,
        "remotes": true,
        "stashes": true,
        "tags": true,
        "worktrees": true,
        "contributors": true,
        "fileHistory": false,
        "repositories": true,
        "searchAndCompare": false,
        "launchpad": false
    },
    "go.diagnostic.vulncheck": "Off",

    "inline-bookmarks.default.words.purple": "@audit\\-issue[\\s], @tag\\-.+[\\s], @new[\\s], @changed[\\s], @removed[\\s]",
    "git.replaceTagsWhenPull": true,
    "claudeCode.preferredLocation": "panel",
    "gitlens.views.commitDetails.files.compact": true,
    "gitlens.views.commitDetails.files.icon": "type",
    "gitlens.views.commitDetails.files.layout": "tree",
    "gitlens.views.commitDetails.files.threshold": 5,
    "window.autoDetectColorScheme": false,
    "extensions.autoUpdate": false,

    // For Juno
    // "go.toolsEnvVars": {
    //     "CGO_LDFLAGS": "-ldl -lm"
    // },

    // Default values:
    // "inline-bookmarks.default.words.blue": "@audit\\-info[\\s], @note[\\s], @remind[\\s], @follow-up[\\s]",
    // "inline-bookmarks.default.words.green": "@audit\\-ok[\\s]",
    // "inline-bookmarks.default.words.purple": "@audit\\-issue[\\s], @tag\\-.+[\\s]",
    // "inline-bookmarks.default.words.red": "@audit[\\s], @todo[\\s]",
}